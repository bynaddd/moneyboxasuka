{
  "name": "dashboard-money-box",
  "rewrites": [
    { "source": "/api/sheets", "destination": "/api/sheets" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
